#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd -- "${SCRIPT_DIR}/.." && pwd)"
CARGO_HOME="${CARGO_HOME:-${HOME}/.cargo}"

MCP_MANIFEST="${BEVY_BRP_MCP_MANIFEST:-}"
if [[ -z "${MCP_MANIFEST}" ]]; then
  MCP_MANIFEST="$(
    find "${CARGO_HOME}/registry/src" \
      -path "*/bevy_brp_mcp-0.18.5/Cargo.toml" \
      -print \
      -quit
  )"
fi

if [[ -z "${MCP_MANIFEST}" || ! -f "${MCP_MANIFEST}" ]]; then
  echo "bevy_brp_mcp 0.18.5 is not available in the Cargo registry cache." >&2
  echo "Run: cargo info bevy_brp_mcp@0.18.5" >&2
  exit 1
fi

exec cargo run \
  --quiet \
  --manifest-path "${MCP_MANIFEST}" \
  --target-dir "${REPO_ROOT}/target/bevy_brp_mcp" \
  --
